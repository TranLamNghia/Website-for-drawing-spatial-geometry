{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "type": "object",
    "required": [
        "metadata",
        "entities",
        "facts",
        "queries"
    ],
    "additionalProperties": false,
    "properties": {
        "metadata": {
            "type": "object",
            "required": [
                "problem_id"
            ],
            "additionalProperties": false,
            "properties": {
                "problem_id": {
                    "type": "string"
                },
                "topic": {
                    "type": "string",
                    "enum": [
                        "geometry_2D",
                        "geometry_3D"
                    ]
                },
                "language": {
                    "type": "string"
                }
            }
        },
        "entities": {
            "type": "object",
            "required": [
                "points",
                "segments",
                "rays",
                "vectors",
                "planes",
                "solids"
            ],
            "additionalProperties": false,
            "properties": {
                "points": {
                    "type": "array",
                    "items": {
                        "type": "string",
                        "pattern": "^([A-Z][0-9]*'*)+$"
                    }
                },
                "segments": {
                    "type": "array",
                    "items": {
                        "type": "string",
                        "pattern": "^([A-Z][0-9]*'*){2}$"
                    }
                },
                "rays": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    }
                },
                "vectors": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    }
                },
                "planes": {
                    "type": "array",
                    "items": {
                        "type": "string",
                        "pattern": "^([A-Z][0-9]*'*)+$"
                    }
                },
                "solids": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    }
                }
            }
        },
        "facts": {
            "type": "array",
            "items": {
                "$ref": "#/definitions/fact"
            }
        },
        "queries": {
            "type": "array",
            "items": {
                "$ref": "#/definitions/query"
            }
        },
        "extraction_meta": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
                "confidence": {
                    "type": "number",
                    "minimum": 0,
                    "maximum": 1
                },
                "notes": {
                    "type": "string"
                }
            }
        }
