            "type": "object",
            "required": [
                "id",
                "type",
                "data",
                "raw_text"
            ],
            "additionalProperties": false,
            "properties": {
                "id": {
                    "type": "string"
                },
                "type": {
                    "type": "string",
                    "enum": [
                        "shape",
                        "length",
                        "ratio",
                        "distance",
                        "perpendicular",
                        "parallel",
                        "intersection",
                        "midpoint",
                        "projection",
                        "angle",
                        "belongs_to",
                        "coplanar",
                        "collinear",
                        "tangent",
                        "inscribed",
                        "circumscribed",
                        "incenter",
                        "circumcenter",
                        "orthocenter",
                        "centroid",
                        "area",
                        "volume",
                        "perimeter"
