                {
                    "$ref": "#/definitions/fact_distance"
                },
                {
                    "$ref": "#/definitions/fact_perpendicular"
                },
                {
                    "$ref": "#/definitions/fact_parallel"
                },
                {
                    "$ref": "#/definitions/fact_intersection"
                },
                {
                    "$ref": "#/definitions/fact_midpoint"
                },
                {
                    "$ref": "#/definitions/fact_projection"
                },
                {
                    "$ref": "#/definitions/fact_angle"
                },
                {
                    "$ref": "#/definitions/fact_belongs_to"
                },
                {
                    "$ref": "#/definitions/fact_coplanar"
                },
                {
                    "$ref": "#/definitions/fact_collinear"
                },
                {
                    "$ref": "#/definitions/fact_tangent"
                },
                {
                    "$ref": "#/definitions/fact_inscribed"
                },
                {
                    "$ref": "#/definitions/fact_circumscribed"
